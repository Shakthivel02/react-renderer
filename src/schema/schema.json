{
  "type": "grid",
  "columns": 1,
  "children": [
    {
      "type": "card",
      "header": [
        {
          "type": "typography",
          "text": "System Users",
          "variant": "h2"
        },
        {
          "type": "button",
          "text": "+",
          "action": "openModal",
          "target": "addUser",
          "variant": "primary"
        }
      ],
      "children": [
        {
          "type": "table",
          "entityKey": "users",
          "pagination": { "pageSize": 5 },
          "columns": [
            { "header": "Full Name", "accessor": "firstName" },
            { "header": "Email", "accessor": "email" },
            { "header": "Role", "accessor": "role" }
          ],
          "actions": [
            { "type": "delete", "label": "Remove" }
          ]
        }
      ]
    },
    {
      "type": "card",
      "children": [
        {
          "type": "typography",
          "text": "Product Inventory (Live API)",
          "variant": "h2"
        },
        {
          "type": "table",
          "entityKey": "products",
          "apiEndpoint": "/products",
          "pagination": { "pageSize": 5 },
          "columns": [
            { "header": "Product Title", "accessor": "title" },
            { "header": "Category", "accessor": "category" },
            { "header": "Price ($)", "accessor": "price" }
          ]
        }
      ]
    }
  ]
}
